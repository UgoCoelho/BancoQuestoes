@model BancoQuestoes.Models.Arquivo

@{
    ViewData["Title"] = "Detalhes do Material";
}

<div class="home-container">

    <!-- VOLTAR -->
    <a asp-action="Index" class="back-btn">
        <i class="bi bi-arrow-left"></i>
        Voltar para arquivos
    </a>

    <!-- HEADER -->
    <div class="period-header">

        <div class="period-header-icon">
            <i class="bi bi-file-earmark-text"></i>
        </div>

        <div class="period-header-text">
            <h1>@Model.Titulo</h1>

            <p>
                Visualização completa do material compartilhado
            </p>
        </div>

    </div>

    <!-- CARD -->
    <div class="upload-content">

        <!-- ESQUERDA -->
        <div class="upload-card">

            <div class="period-info">
                <i class="bi bi-person"></i>

                <strong>Professor:</strong>

                <span>@Model.Professor</span>
            </div>

            <hr class="details-divider" />

            <div class="period-info">
                <i class="bi bi-tags"></i>

                <strong>Tag:</strong>

                <span>@Model.Tag</span>
            </div>

            <hr class="details-divider" />

            <div class="period-info">
                <i class="bi bi-chat-left-text"></i>

                <strong>Descrição:</strong>
            </div>

            <p class="details-description">
                @Model.Descricao
            </p>

            <div class="form-row">

                <div class="stats-card">

                    <div class="icon-box gradient-blue">
                        <i class="bi bi-mortarboard"></i>
                    </div>

                    <h4>Curso</h4>

                    <p>@Model.Curso?.Nome</p>

                </div>

                <div class="stats-card">

                    <div class="icon-box gradient-neon">
                        <i class="bi bi-book"></i>
                    </div>

                    <h4>Matéria</h4>

                    <p>@Model.Materia?.Nome</p>

                </div>

            </div>

            <div class="details-badge-container">

                <div class="badge">
                    @Model.TipoArquivo?.Nome
                </div>

            </div>

            <!-- BUTTONS -->
            <div class="button-group">

                <a asp-action="Index"
                   class="btn-cancel">

                    VOLTAR

                </a>

                <a asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="btn-submit details-edit-btn">

                    Editar Material

                </a>

            </div>

        </div>

        <!-- SIDE -->
        <div class="side-content">

            <div class="approval-card">

                <h3>
                    <i class="bi bi-info-circle"></i>
                    Informações do Material
                </h3>

                <div class="step">

                    <span>
                        <i class="bi bi-file-earmark"></i>
                    </span>

                    @Model.TipoArquivo?.Nome

                </div>

                <div class="step">

                    <span>
                        <i class="bi bi-bookmark"></i>
                    </span>

                    @Model.Materia?.Nome

                </div>

                <div class="step">

                    <span>
                        <i class="bi bi-mortarboard"></i>
                    </span>

                    @Model.Curso?.Nome

                </div>

            </div>

        </div>

    </div>

</div>