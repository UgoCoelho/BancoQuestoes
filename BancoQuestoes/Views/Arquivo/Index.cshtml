@model IEnumerable<BancoQuestoes.Models.Arquivo>

@{
    ViewData["Title"] = "Arquivos";
}

<div class="home-container">

    <!-- HEADER -->
    <div class="period-header">

        <div class="period-header-icon">
            <i class="bi bi-folder2-open"></i>
        </div>

        <div class="period-header-text">
            <h1>Arquivos Compartilhados</h1>
            <p>
                Materiais organizados por período, matéria e professor
            </p>
        </div>

    </div>

    <!-- BOTAO -->
    <div style="margin-bottom: 25px;">

        <a asp-action="Create" class="btn-submit"
           style="
                display:flex;
                align-items:center;
                justify-content:center;
                width:220px;
                height:52px;
                text-decoration:none;
           ">

            <i class="bi bi-plus-lg"></i>
            &nbsp; Novo Arquivo

        </a>

    </div>

    <!-- GRID -->
    <div class="periods-grid">

        @foreach (var item in Model.OrderBy(x => x.Curso.Nome)
                .ThenBy(x => x.Materia.Nome)
                .ThenBy(x => x.Titulo))
        {
            <div class="period-box">

                <div class="period-number">
                    <i class="bi bi-file-earmark-text"></i>
                </div>

                <h3>@item.Titulo</h3>

                <div class="period-info">
                    <i class="bi bi-book"></i>
                    <span>@item.Materia?.Nome</span>
                </div>

                <div class="period-info">
                    <i class="bi bi-mortarboard"></i>
                    <span>@item.Curso?.Nome</span>
                </div>

                <div class="period-info">
                    <i class="bi bi-person"></i>
                    <span>@item.Professor</span>
                </div>

                <div class="period-info">
                    <i class="bi bi-tag"></i>
                    <span>@item.TipoArquivo?.Nome</span>
                </div>

                <div class="period-info">
                    <i class="bi bi-chat-left-text"></i>
                    <span>@item.Descricao</span>
                </div>

                @if (!string.IsNullOrEmpty(item.Tag))
                {
                    <div class="period-new">
                        #@item.Tag
                    </div>
                }

                <div class="period-link">

                    <div style="display:flex; gap:12px;">

                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           style="text-decoration:none; color:#2563eb;">
                            Editar
                        </a>

                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           style="text-decoration:none; color:#2563eb;">
                            Detalhes
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           style="text-decoration:none; color:#ef4444;">
                            Excluir
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>