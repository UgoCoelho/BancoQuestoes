@model IEnumerable<BancoQuestoes.Models.Usuario>

<div class="crud-page">

    <div class="crud-header">

        <h1 class="crud-title">
            Usu·rios
        </h1>

        <a asp-action="Create"
           class="crud-btn">
            + Novo Usu·rio
        </a>

    </div>

    <div class="crud-card">

        <table class="crud-table">

            <thead>
                <tr>
                    <th>MatrÌcula</th>
                    <th>Nome</th>
                    <th>Curso</th>
                    <th>AÁes</th>
                </tr>
            </thead>

            <tbody>

            @foreach(var item in Model)
            {
                <tr>

                    <td>@item.Matricula</td>

                    <td>@item.Nome</td>

                    <td>
                        <span class="crud-badge">
                            @item.Curso?.Nome
                        </span>
                    </td>

                    <td>
                        <div class="crud-actions">

                            <a asp-action="Edit"
                               asp-route-id="@item.UsuarioId">
                               Editar
                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.UsuarioId">
                                Detalhes
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.UsuarioId">
                               Excluir
                            </a>

                        </div>

                    </td>

                </tr>
            }

            </tbody>

        </table>

    </div>

</div>