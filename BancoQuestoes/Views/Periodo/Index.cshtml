@model IEnumerable<BancoQuestoes.Models.Periodo>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Numero)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CursoId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Curso)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Numero)
            </td>
            <td>
                @Html.DisplayFor(model => item.CursoId)
            </td>
            <td>
                @Html.DisplayFor(model => item.Curso)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.PeriodoId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.PeriodoId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.PeriodoId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
