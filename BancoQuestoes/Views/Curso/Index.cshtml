@model IEnumerable<BancoQuestoes.Models.Curso>

@{
    ViewData["Title"] = "Cursos";
}

<div class="crud-page">

    <div class="crud-header">

        <h1 class="crud-title">
            Cursos
        </h1>

        <a asp-action="Create"
           class="crud-btn">
            + Novo Curso
        </a>

    </div>

    <div class="crud-card">

        <table class="crud-table">

            <thead>
                <tr>
                    <th>Nome do Curso</th>
                    <th style="width:220px;">
                        Ações
                    </th>
                </tr>
            </thead>

            <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>

                        <span class="crud-badge">
                            @item.Nome
                        </span>

                    </td>

                    <td>

                        <div class="crud-actions">

                            <a asp-action="Edit"
                               asp-route-id="@item.CursoId">
                                Editar
                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.CursoId">
                                Detalhes
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.CursoId">
                                Excluir
                            </a>

                        </div>

                    </td>

                </tr>
            }

            </tbody>

        </table>

    </div>

</div>