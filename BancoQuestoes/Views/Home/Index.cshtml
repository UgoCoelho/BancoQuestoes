@{
    var nome = Context.Session.GetString("UsuarioNome");
    var curso = Context.Session.GetString("UsuarioCurso");
    var periodo = Context.Session.GetInt32("UsuarioPeriodo");
}

<div class="card p-4 mb-4">
    <h4>Bem-vindo, @nome! 👋</h4>
    <p class="text-muted">Curso: <strong>@curso</strong> — Período: <strong>@periodo</strong></p>
</div>

<div class="home-container">
    <section>
       <h1 class="hero-title">
            Explore Cursos
        </h1>
        <p class="hero-subtitle">
            Encontre exercícios, listas e resumos compartilhados pela comunidade
        </p>
    </section>
 </div>

    <!-- stats -->

    <section class="stats-grid">
        <div class="stats-card">
            <div class="icon-box gradient-blue">
                <i class="bi bi-file-earmark-text"></i>
            </div>
            <h2>247</h2>
            <p>Total de Materiais</p>
        </div>
        <div class="stats-card">
            <div class="icon-box gradient-neon">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
            <h2>+15</h2>
            <p>Novos essa semana</p>
        </div>
        <div class="stats-card">
            <div class="icon-box gradient-blue">
                <i class="bi bi-people"></i>
            </div>
            <h2>1.234</h2>
            <p>Colaboradores</p>
        </div>
    </section>

    <!-- CURSOS -->

    <section class="courses-grid">

        <!-- SI -->
        <div class="modern-course-card">

            <div class="course-top">
                <div class="course-icon blue">
                    SI
                </div>
            </div>

            <h2 class="course-name">Sistemas de Informação</h2>

            <div class="course-stats">

                <div class="mini-stat">
                    <i class="bi bi-book"></i>
                    <strong>42</strong>
                    <span>Matérias</span>
                </div>

                <div class="mini-stat">
                    <i class="bi bi-file-earmark-text"></i>
                    <strong>324</strong>
                    <span>Materiais</span>
                </div>

                <div class="mini-stat">
                    <i class="bi bi-people"></i>
                    <strong>450</strong>
                    <span>Alunos</span>
                </div>

            </div>

            <div class="course-periods">
                <i class="bi bi-mortarboard"></i>
                <div>
                    <strong>8 Períodos Disponíveis</strong>
                    <p>Do 1º ao 8º período</p>
                </div>
            </div>

            <a asp-controller="Home"
               asp-action="Periodos"
               class="explore-link">
                Explorar Períodos
                <i class="bi bi-arrow-right"></i>
            </a>

        </div>

        <!-- ES -->

        <div class="modern-course-card">

            <div class="course-top">
                <div class="course-icon purple">
                    ES
                </div>
            </div>

            <h2 class="course-name">Engenharia de Software</h2>

            <div class="course-stats">

                <div class="mini-stat">
                    <i class="bi bi-book"></i>
                    <strong>38</strong>
                    <span>Matérias</span>
                </div>

                <div class="mini-stat">
                    <i class="bi bi-file-earmark-text"></i>
                    <strong>287</strong>
                    <span>Materiais</span>
                </div>

                <div class="mini-stat">
                    <i class="bi bi-people"></i>
                    <strong>380</strong>
                    <span>Alunos</span>
                </div>

            </div>

            <div class="course-periods">
                <i class="bi bi-mortarboard"></i>
                <div>
                    <strong>8 Períodos Disponíveis</strong>
                    <p>Do 1º ao 8º período</p>
                </div>
            </div>

            <a href="#"
               class="explore-link">
                Explorar Períodos
                <i class="bi bi-arrow-right"></i>
            </a>

        </div>

    </section>

    <!-- CARD AZUL -->

    <div class="info-banner">

        <div class="banner-icon">
            <i class="bi bi-stars"></i>
        </div>

        <div>
            <h3>Navegação Organizada</h3>
            <p>
                Escolha seu curso, depois navegue pelos períodos e encontre
                todas as matérias organizadas de forma clara e intuitiva.
            </p>
        </div>

    </div>
