@{
    ViewData["Title"] = "Períodos";
}

<div class="home-container period-page">

    <a asp-controller="Home"
       asp-action="Index"
       class="back-btn">
        <i class="bi bi-arrow-left"></i>
        Voltar para cursos
    </a>

    <!-- HEADER -->

    <div class="period-header">

        <div class="period-header-icon">
            <i class="bi bi-journal-bookmark"></i>
        </div>

        <div class="period-header-text">
            <h1>Sistemas de Informação</h1>
            <p>Selecione o período para explorar as matérias disponíveis</p>
        </div>

    </div>

    <!-- GRID -->

    <div class="periods-grid">

        @for (int i = 1; i <= 8; i++)
        {
            <div class="period-box">

                @if (i <= 4)
                {
                    <span class="period-badge-new">
                        +@(i)
                    </span>
                }

                <div class="period-number">
                    @(i)º
                </div>

                <h3>@(i)º Período</h3>

                <div class="period-info">
                    <i class="bi bi-book"></i>
                    <span>5 matérias</span>
                </div>

                <div class="period-info">
                    <i class="bi bi-file-earmark-text"></i>
                    <span>@(30 + i * 3) materiais</span>
                </div>

                <a asp-controller="Materia"
                   asp-action="PorPeriodo"
                   asp-route-periodo="@i"
                   class="period-link">

                    Ver matérias
                    <i class="bi bi-arrow-right"></i>

                </a>

            </div>
        }

    </div>

    <!-- FOOTER -->

    <div class="period-footer">

        <div class="period-footer-icon">
            <i class="bi bi-calendar-check"></i>
        </div>

        <div>
            <strong>Organização por Período</strong>

            <p>
                Cada período contém as matérias específicas daquele semestre.
                Clique em um período para visualizar disciplinas,
                materiais e conteúdos disponíveis.
            </p>
        </div>

    </div>

</div>