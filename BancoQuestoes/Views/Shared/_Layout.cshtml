<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BancoQuestoes</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BancoQuestoes.styles.css" asp-append-version="true" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    @RenderSection("Styles", required: false)
</head>

<body>

<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm custom-navbar mb-3">
        <div class="container-fluid">

            <!-- LOGO -->
            <a class="navbar-brand logo" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="logo-icon">
                    <i class="bi bi-journal-check"></i>
                </span>

                <div>
                    <div class="logo-title">BOTARUMNOME</div>
                    <div class="logo-subtitle">Plataforma Acadêmica</div>
                </div>
            </a>

            <!-- BOTÃO MOBILE -->
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- MENU -->
            <div class="navbar-collapse collapse">

                <!-- ESQUERDA -->
                <ul class="navbar-nav navbar-nav-left">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Início</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacidade</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Materia" asp-action="Index">Materia</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Usuario" asp-action="Index">Usuario</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="TipoArquivo" asp-action="Index">TipoArquivo</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Curso" asp-action="Index">Curso</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Arquivo" asp-action="Index">Arquivo</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Periodo" asp-action="Index">Periodo</a></li>
                </ul>

                <!-- DIREITA -->
                <ul class="navbar-nav ms-auto navbar-nav-right">
                    <li class="nav-item nav-icon-item">
                        <a class="nav-link nav-icon-link" href="#">
                            <i class="bi bi-search"></i>
                        </a>
                    </li>

                    <li class="nav-item nav-icon-item">
                        <a class="nav-link nav-icon-link" href="#">
                            <i class="bi bi-bell"></i>
                            <span class="nav-badge"></span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-user" href="#">
                            <div class="nav-avatar">LL</div>

                            <div class="nav-user-info">
                                <span class="nav-user-name">Laura Linda</span>
                                <span class="nav-user-role">Estudante</span>
                            </div>
                        </a>
                    </li>
                </ul>

            </div>
        </div>
    </nav>
</header>

<!-- CONTEÚDO -->
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<!-- FOOTER -->
<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - BancoQuestoes
    </div>
</footer>

<!-- SCRIPTS -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>