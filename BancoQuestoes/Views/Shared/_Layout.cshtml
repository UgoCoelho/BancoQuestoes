<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BancoQuestoes</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BancoQuestoes.styles.css" asp-append-version="true" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    @RenderSection("Styles", required: false)
</head>

<body>

@{
    // Lê os dados da sessão em qualquer view
    var nomeUsuario = Context.Session.GetString("UsuarioNome");
    var cursoUsuario = Context.Session.GetString("UsuarioCurso");
    var role = Context.Session.GetString("UsuarioRole"); // "Admin" ou "Usuario"
    bool isAdmin = role == "Admin";

    // Iniciais do nome para o avatar
    string iniciais = "";
    if (!string.IsNullOrEmpty(nomeUsuario))
    {
        var partes = nomeUsuario.Split(' ');
        iniciais = partes.Length >= 2
            ? $"{partes[0][0]}{partes[^1][0]}"
            : nomeUsuario[..Math.Min(2, nomeUsuario.Length)];
        iniciais = iniciais.ToUpper();
    }
}
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm custom-navbar mb-3">
        <div class="container-fluid">

            <!-- LOGO -->
            <a class="navbar-brand logo" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="logo-icon">
                    <i class="bi bi-journal-check"></i>
                </span>

                <div>
                    <div class="logo-title">KNOWLI</div>
                    <div class="logo-subtitle">Plataforma Acadêmica</div>
                </div>
            </a>

            <!-- BOTÃO MOBILE -->
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- MENU -->
            <div class="navbar-collapse collapse">

                <!-- ESQUERDA -->
                <ul class="navbar-nav navbar-nav-left">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Início</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacidade</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Materia" asp-action="Index">Materia</a></li>
                    @* Menus visíveis apenas para Admin *@
                    @if (isAdmin)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-shield-lock me-1"></i> Admin
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Usuario" asp-action="Index">Usuários</a></li>
                                <li><a class="dropdown-item" asp-controller="Curso" asp-action="Index">Cursos</a></li>
                                <li><a class="dropdown-item" asp-controller="TipoArquivo" asp-action="Index">Tipos de Arquivo</a></li>
                            </ul>
                        </li>
                    }
                </ul>

                <!-- DIREITA -->
                <ul class="navbar-nav ms-auto navbar-nav-right">
                    <li class="nav-item nav-icon-item">
                        <a class="nav-link nav-icon-link" href="#">
                            <i class="bi bi-search"></i>
                        </a>
                    </li>

                    <li class="nav-item nav-icon-item">
                        <a class="nav-link nav-icon-link" href="#">
                            <i class="bi bi-bell"></i>
                            <span class="nav-badge"></span>
                        </a>
                    </li>

                    @if (!string.IsNullOrEmpty(nomeUsuario))
                    {
                        <!-- Usuário logado: mostra nome + logout -->
                        <li class="nav-item dropdown">
                            <a class="nav-link nav-user dropdown-toggle"
                                href="#"
                                id="userDropdown"
                                role="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                                <div class="nav-avatar">@iniciais</div>
                                <div class="nav-user-info">
                                    <span class="nav-user-name">@nomeUsuario</span>
                                    @if (isAdmin)
                                    {
                                        <span class="badge bg-warning text-dark ms-1" style="font-size:0.65rem;">ADMIN</span>
                                    }
                                    <span class="nav-user-role">@cursoUsuario</span>
                                </div>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                <li>
                                    <a class="dropdown-item text-danger" asp-controller="Login" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-1"></i> Sair
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <!-- Não logado: mostra botão de login -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Login" asp-action="Index">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Entrar
                            </a>
                        </li>
                    }
                </ul>

            </div>
        </div>
    </nav>
</header>

<!-- CONTEÚDO -->
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<!-- FOOTER -->
<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - BancoQuestoes
    </div>
</footer>

<!-- SCRIPTS -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>